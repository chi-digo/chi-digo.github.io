{
  "version": "1.0",
  "description": "Swahili-to-Digo sound correspondence rules for fuzzy search",
  "rules": [
    {
      "id": "nz_ndz",
      "swahili": "nz",
      "digo": "ndz",
      "example": {
        "sw": "nzuri",
        "dg": "ndzuri"
      },
      "position": "any"
    },
    {
      "id": "bw_gbw",
      "swahili": "bw",
      "digo": "gbw",
      "example": {
        "sw": "bwana",
        "dg": "gbwana"
      },
      "position": "any"
    },
    {
      "id": "kw_kpw",
      "swahili": "kw",
      "digo": "kpw",
      "example": {
        "sw": "kwekwe",
        "dg": "kpwekpwe"
      },
      "position": "any"
    },
    {
      "id": "ch_ts",
      "swahili": "ch",
      "digo": "ts",
      "example": {
        "sw": "chache",
        "dg": "tsache"
      },
      "position": "before_vowel"
    },
    {
      "id": "j_dz",
      "swahili": "j",
      "digo": "dz",
      "example": {
        "sw": "jicho",
        "dg": "dzitso"
      },
      "position": "any"
    },
    {
      "id": "initial_h",
      "swahili": "",
      "digo": "h",
      "example": {
        "sw": "enda",
        "dg": "henda"
      },
      "position": "word_initial_before_vowel",
      "note": "Digo often adds initial h- before vowels"
    }
  ],
  "digraph_normalizations": [
    {
      "from": "ng",
      "to": "ng'",
      "note": "Velar nasal often written without apostrophe"
    }
  ]
}