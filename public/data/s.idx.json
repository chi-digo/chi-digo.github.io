 "sukukuu", "hw": "sukukuu", "id": "sukukuu", "pos": "dzina", "eq": "public holiday, day of celebration", "eq_sw": "sikukuu", "eq_dg": "Siku ya sherehe ya tsi au ya dini."}, {"sk": "sukuli", "hw": "sukuli", "id": "sukuli", "pos": "dzina", "eq": "school", "eq_sw": "skuli, shule", "eq_dg": "Phatu ambapo anache anaphiya kusoma. Shule."}, {"sk": "sukuma", "hw": "sukuma", "id": "sukuma.1", "pos": "dzina", "eq": "tabwi", "eq_sw": "", "eq_dg": ""}, {"sk": "sukuma", "hw": "sukuma", "id": "sukuma.2", "pos": "chihendo", "eq": "push", "eq_sw": "kusukuma", "eq_dg": "Kuika nguvu na kugeneza chitu mbere."}, {"sk": "suluhu", "hw": "suluhu", "id": "suluhu", "pos": "dzina", "eq": "solution, reconciliation", "eq_sw": "suluhu", "eq_dg": "Njia ya kumaliza tatizo au malumbano kpwa amani."}, {"sk": "sumba", "hw": "sumba", "id": "sumba.1", "pos": "dzina", "eq": "needle made either from metal or wood used for sewing together a", "eq_sw": "", "eq_dg": "Sindano ya chuma au ya muhi ya kushonera makuti au nyasi."}, {"sk": "sumba", "hw": "sumba", "id": "sumba.2", "pos": "chihendo", "eq": "tremble, to shake lightly", "eq_sw": "kutikisika", "eq_dg": "Kutikisika kidogo, kutetema kpwa nguvu."}, {"sk": "sumbiza", "hw": "sumbiza", "id": "sumbiza", "pos": "chihendo", "eq": "make something swing", "eq_sw": "kubembeza", "eq_dg": "Kuhenda chitu chitikisike au kibembe."}, {"sk": "sumu", "hw": "sumu", "id": "sumu", "pos": "dzina", "eq": "poison", "eq_sw": "sumu", "eq_dg": "Chitu ambacho chikimizwa au kutiywa mwirini chinaolaga au kuumiza."}, {"sk": "sunduzi", "hw": "sunduzi", "id": "sunduzi", "pos": "dzina", "eq": "", "eq_sw": "", "eq_dg": ""}, {"sk": "sununu", "hw": "-sununu", "id": "sununu", "pos": "sifa", "eq": "stand-offish, aloof", "eq_sw": "sununu", "eq_dg": "Mutu ambaye kagombwa na atu, wa kukala kando."}, {"sk": "sura", "hw": "sura", "id": "sura.1", "pos": "dzina", "eq": "appearance, face", "eq_sw": "sura", "eq_dg": "Uso wa mutu au muonekano wa chitu."}, {"sk": "sura", "hw": "sura", "id": "sura.2", "pos": "dzina", "eq": "chapter", "eq_sw": "sura", "eq_dg": "Sehemu mwenga ya chitabu au Qurani."}, {"sk": "suruwale", "hw": "suruwale", "id": "suruwale", "pos": "dzina", "eq": "trousers", "eq_sw": "suruali", "eq_dg": "Nguwo ya migulu ambayo inavwalwa ni alume na achetu."}, {"sk": "susurika", "hw": "susurika", "id": "susurika", "pos": "chihendo", "eq": "be coming frequently", "eq_sw": "kuja mahali mara nyingi", "eq_dg": "Kukpwedza phatu fulani mara nyinji."}, {"sk": "suwa", "hw": "suwa", "id": "suwa", "pos": "chihendo", "eq": "wash e.g. dishes, furniture, floors", "eq_sw": "kuosha", "eq_dg": "Kuosha vitu dza sahani, samani, au sakafu."}, {"sk": "suya", "hw": "suya", "id": "suya", "pos": "dzina", "eq": "dirt that is removed by sieving", "eq_sw": "uchafu unaobaki baada ya kuchunga au kupepeta", "eq_dg": "Uchafu unaotsala bada ya kupephetera au kuchuja nafaka."}, {"sk": "suza", "hw": "suza", "id": "suza", "pos": "chihendo", "eq": "rinse", "eq_sw": "kusuza", "eq_dg": "Kuosha chitu kpwa madzi masafi bada ya kuchisuwa."}, {"sk": "swali", "hw": "swali", "id": "swali", "pos": "dzina", "eq": "a question", "eq_sw": "swali", "eq_dg": "Neno au sentensi inayouza chitu."}, {"sk": "swena", "hw": "swena", "id": "swena", "pos": "chihendo", "eq": "dry up (e.g. a river)", "eq_sw": "kukauka (k.m", "eq_dg": "Madzi kuisha phatu fulani, dza muho kuuma."}, {"sk": "swi", "hw": "swi", "id": "swi", "pos": "dzina", "eq": "short form of swiswi (‘we’) used in conjunction with e.g. enye (ourselves)", "eq_sw": "swiswi (‘sisi’) kwa kifupi", "eq_dg": "Neno ra kufupisha 'swiswi' — sisi."}, {"sk": "swiswi", "hw": "swiswi", "id": "swiswi", "pos": "dzina", "eq": "we, us (used alone, often for emphasis)", "eq_sw": "sisi", "eq_dg": "Sisi, swino. Neno ra kuhikishira."}]